<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Filters Border Styling -->
    <Style Selector="Border.FiltersBorder">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="Margin" Value="0,0,0,15" />
    </Style>

    <!-- Result Item Card Styling -->
    <Style Selector="Border.ResultItemCard">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.ResultItemCard:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>

    <!-- Badges Panel -->
    <Style Selector="WrapPanel.BadgesPanel">
        <Setter Property="Margin" Value="0,5,0,0" />
    </Style>

    <!-- Badge Border Base Styling -->
    <Style Selector="Border.Badge">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Category Badge -->
    <Style Selector="Border.CategoryBadge">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!-- Topic Badge -->
    <Style Selector="Border.TopicBadge">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
    </Style>

    <!-- Section Badge -->
    <Style Selector="Border.SectionBadge">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
    </Style>

    <!-- Status Badge -->
    <Style Selector="Border.StatusBadge">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
    </Style>
</Styles>
