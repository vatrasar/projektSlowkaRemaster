<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- TextBox Search Input Styling -->
    <Style Selector="TextBox.SearchInput">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Watermark" Value="Search..." />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBox.SearchInput:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
    </Style>

    <!-- Filter Combo (ComboBox) Styling -->
    <Style Selector="ComboBox.FilterCombo">
        <Setter Property="Width" Value="160" />
        <Setter Property="Height" Value="32" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Filter Item StackPanel spacing -->
    <Style Selector="StackPanel.FilterItem">
        <Setter Property="Margin" Value="0,5,15,5" />
    </Style>

    <!-- Search Progress Bar Styling -->
    <Style Selector="ProgressBar.SearchProgress">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- Results List Box Styling -->
    <Style Selector="ListBox.ResultsList">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>
</Styles>
