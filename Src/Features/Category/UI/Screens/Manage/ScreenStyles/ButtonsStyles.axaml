<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Primary Button -->
    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="10,12" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.Primary:pointerover">
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- Primary Small Button -->
    <Style Selector="Button.PrimarySmall">
        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.PrimarySmall:pointerover">
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- Secondary Small Button -->
    <Style Selector="Button.SecondarySmall">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlTransientBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.SecondarySmall:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>

    <!-- Danger Small Button -->
    <Style Selector="Button.DangerSmall">
        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnErrorBrush}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.DangerSmall:pointerover">
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- Success Small Button -->
    <Style Selector="Button.SuccessSmall">
        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnSuccessBrush}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.SuccessSmall:pointerover">
        <Setter Property="Opacity" Value="0.9" />
    </Style>
</Styles>
