<rxui:ReactiveUserControl x:TypeArguments="local:QuestionEditorViewModel"
                           x:DataType="local:QuestionEditorViewModel"
                           xmlns="https://github.com/avaloniaui"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:rxui="http://reactiveui.net"
                           xmlns:local="using:ProjektSlowkaRemasterd.Src.Features.Question.UI.Screens.QuestionEditor"
                           xmlns:models="using:ProjektSlowkaRemasterd.Src.Core.Domain.Models"
                           x:Class="ProjektSlowkaRemasterd.Src.Features.Question.UI.Screens.QuestionEditor.QuestionEditorView">

    <UserControl.Styles>
        <StyleInclude Source="/Src/Features/Question/UI/Screens/QuestionEditor/ScreenStyles/QuestionEditorStyles.axaml" />
    </UserControl.Styles>

    <UserControl.Resources>
        <local:ImagePathToBitmapConverter x:Key="PathToBitmapConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title & Back Button -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
                <Button Grid.Column="0" x:Name="BackButton" Content="← Back" Classes="Secondary" VerticalAlignment="Center" Margin="0,0,15,0" />
                <TextBlock Grid.Column="1" x:Name="TitleTextBlock" Classes="Title" VerticalAlignment="Center"/>
            </Grid>

            <!-- Main Split Layout -->
            <Grid Grid.Row="1" ColumnDefinitions="2*,1.1*">
                
                <!-- Left Column: Form -->
                <Border Grid.Column="0" Classes="Card" Margin="0,0,20,0" VerticalAlignment="Stretch">
                    <Grid RowDefinitions="*,Auto,Auto">
                        
                        <!-- Input Panels in UniformGrid to share height equally -->
                        <UniformGrid Grid.Row="0" Columns="1">
                            
                            <!-- Question Input -->
                            <Grid x:Name="QuestionInputPanel" RowDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                                <!-- Question Header Row -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Text="Question" Classes="Label" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="ChooseQuestionImageButton" Content="Choose Image File" Classes="SecondarySmall" />
                                        <Button x:Name="PasteQuestionImageButton" Content="Paste Clipboard" Classes="SecondarySmall" />
                                    </StackPanel>
                                </Grid>
                                
                                <TextBox Grid.Row="1" x:Name="QuestionTextBox" Classes="Input" AcceptsReturn="True" TextWrapping="Wrap" Watermark="Enter question..." MinHeight="100" VerticalAlignment="Stretch" />
                                
                                <!-- Question Images Attachment -->
                                <ItemsControl Grid.Row="2" x:Name="QuestionImagesItemsControl" Margin="0,5,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Classes="ImageThumbContainer">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                                                        <Image Source="{Binding Converter={StaticResource PathToBitmapConverter}}" Height="40" Width="40" Stretch="UniformToFill"/>
                                                        <TextBlock Text="{Binding}" Classes="ImageNameText" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                    <Button x:Name="RemoveQuestionImageButton" Content="✕" Click="OnRemoveQuestionImageClick" Classes="RemoveImageButton" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Answer Input -->
                            <Grid x:Name="AnswerInputPanel" RowDefinitions="Auto,*,Auto" Margin="0,0,0,10">
                                <!-- Answer Header Row -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Text="Answer / Content" Classes="Label" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="ChooseAnswerImageButton" Content="Choose Image File" Classes="SecondarySmall" />
                                        <Button x:Name="PasteAnswerImageButton" Content="Paste Clipboard" Classes="SecondarySmall" />
                                    </StackPanel>
                                </Grid>

                                <TextBox Grid.Row="1" x:Name="AnswerTextBox" Classes="Input" AcceptsReturn="True" TextWrapping="Wrap" Watermark="Enter answer or note content..." MinHeight="100" VerticalAlignment="Stretch" />
                                
                                <!-- Answer Images Attachment -->
                                <ItemsControl Grid.Row="2" x:Name="AnswerImagesItemsControl" Margin="0,5,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Classes="ImageThumbContainer">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                                                        <Image Source="{Binding Converter={StaticResource PathToBitmapConverter}}" Height="40" Width="40" Stretch="UniformToFill"/>
                                                        <TextBlock Text="{Binding}" Classes="ImageNameText" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                    <Button x:Name="RemoveAnswerImageButton" Content="✕" Click="OnRemoveAnswerImageClick" Classes="RemoveImageButton" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            
                        </UniformGrid>

                        <!-- Success / Error Text -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock x:Name="SuccessTextBlock" Classes="Success" HorizontalAlignment="Center" Margin="0,2,0,2" />
                            <TextBlock x:Name="ErrorTextBlock" Classes="Error" HorizontalAlignment="Center" Margin="0,2,0,2" />
                        </StackPanel>

                        <!-- Save Button -->
                        <Button Grid.Row="2" x:Name="SaveButton" Content="Save Question" Classes="Primary" HorizontalAlignment="Center" HorizontalContentAlignment="Center" Width="200" Margin="0,5,0,0" />
                    </Grid>
                </Border>

                <!-- Right Column: Options Card -->
                <Border Grid.Column="1" Classes="Card" VerticalAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Options" Classes="SubTitle" Margin="0,0,0,5" />
                            
                            <!-- Category -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Category" Classes="Label" />
                                <ComboBox x:Name="CategoryComboBox" HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Category">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Topic -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Topic (Optional)" Classes="Label" />
                                <ComboBox x:Name="TopicComboBox" HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Topic">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Section -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Section (Optional)" Classes="Label" />
                                <ComboBox x:Name="SectionComboBox" HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Section">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Custom Section Name -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Or create new Section name" Classes="Label" />
                                <TextBox x:Name="CustomSectionTextBox" Classes="Input" Watermark="Type new section name... (requires Topic selected)" />
                            </StackPanel>

                            <!-- Checkboxes -->
                            <StackPanel Spacing="8" Margin="0,5,0,5">
                                <CheckBox x:Name="IsNoteCheckBox" Classes="Toggle" Content="Is Note" />
                                <CheckBox x:Name="IsProblematicCheckBox" Classes="Toggle" Content="Mark as Problematic" />
                            </StackPanel>

                            <!-- Group Connection ID -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Group Connection ID (Optional)" Classes="Label" />
                                <TextBox x:Name="GroupIdTextBox" Classes="Input" Watermark="Numeric group ID (e.g. 5) to link related questions" />
                            </StackPanel>

                            <!-- Edit Last Added Button Wrapper -->
                            <Border x:Name="LastAddedPreviewBorder" Margin="0,8,0,0">
                                <Button x:Name="EditLastAddedButton" Content="Edit Last Question" Classes="Secondary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</rxui:ReactiveUserControl>
